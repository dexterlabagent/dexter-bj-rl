# Base URL - Required for metadata generation (default: https://delph.tech for development)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Redis - Required for credit system and rate limiting
# Local dev: run `docker compose up -d` from the repo root
REDIS_URL="redis://localhost:6379"

# Credit limits - Optional (defaults: 50 for auth, 10 for IP)
FREE_CREDITS_LIMIT_REQUESTS_AUTH=50
FREE_CREDITS_LIMIT_REQUESTS_IP=10

# Sentry Error Tracking - Optional
SENTRY_DSN=

# Logging - Optional
LOG_LEVEL=debug

# PostHog Analytics - Optional
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Hotjar Analytics - Optional
NEXT_PUBLIC_HOTJAR_SITE_ID=
NEXT_PUBLIC_HOTJAR_VERSION=

# Jina AI - Optional (for web scraping)
JINA_API_KEY=

# Token Dashboard - Token address for DexScreener data
NEXT_PUBLIC_TOKEN_ADDRESS=

# Google Gemini API - Optional
GEMINI_API_KEY=